@using AgendaFisio.Front.Models

<div class="pro-scheduler">
    <div class="pro-scheduler__grid" style="@GridColumns">
        <div class="pro-scheduler__corner"></div>

        @foreach (var dia in DiasSemana)
        {
            <div class="pro-scheduler__header">
                <span class="pro-scheduler__day-label">
                    @dia.ToString("dddd dd MMM", _culture)
                </span>
            </div>
        }

        <div class="pro-scheduler__hours" style="grid-template-rows: repeat(@TotalHours, @(AltoHoraPx)px);">
            @foreach (var hour in Hours)
            {
                <div class="pro-scheduler__hour">@($"{hour:00}:00")</div>
            }
        </div>

        @foreach (var dia in DiasSemana)
        {
            <div class="pro-scheduler__column" style="height: @(ColumnHeight)px;">
                <div class="pro-scheduler__column-lines" style="grid-template-rows: repeat(@(TotalHours * 2), 1fr);">
                    @foreach (var slot in HalfHourSlots)
                    {
                        <div class="pro-scheduler__slot"></div>
                    }
                </div>

                @foreach (var cita in GetCitasDia(dia))
                {
                    <div class="pro-appointment @GetEstadoClass(cita.Estado)"
                         style="@GetAppointmentStyle(cita)">
                        <div class="pro-appointment__row">
                            <span class="pro-appointment__time">
                                @cita.FechaHoraInicio.ToString("H:mm") - @cita.FechaHoraFin.ToString("H:mm")
                            </span>
                        </div>
                        <div class="pro-appointment__patient">@cita.PacienteNombre</div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private readonly System.Globalization.CultureInfo _culture = new("es-ES");

    [Parameter] public DateTime FechaInicioSemana { get; set; }
    [Parameter] public List<DashboardCitaDto> Citas { get; set; } = new();

    [Parameter] public int HoraInicio { get; set; } = 8;
    [Parameter] public int HoraFin { get; set; } = 20;
    [Parameter] public int AltoHoraPx { get; set; } = 72;

    private IEnumerable<DateTime> DiasSemana =>
        Enumerable.Range(0, 7).Select(i => FechaInicioSemana.Date.AddDays(i));

    private IEnumerable<int> Hours => Enumerable.Range(HoraInicio, HoraFin - HoraInicio + 1);

    private int TotalHours => HoraFin - HoraInicio + 1;
    private int ColumnHeight => TotalHours * AltoHoraPx;

    private IEnumerable<int> HalfHourSlots => Enumerable.Range(0, TotalHours * 2);

    private string GridColumns =>
        $"grid-template-columns: 70px repeat(7, minmax(140px, 1fr));";

    private IEnumerable<DashboardCitaDto> GetCitasDia(DateTime dia)
        => Citas
            .Where(c => c.FechaHoraInicio.Date == dia.Date)
            .OrderBy(c => c.FechaHoraInicio);

    private string GetAppointmentStyle(DashboardCitaDto cita)
    {
        var visibleStartMinutes = HoraInicio * 60;
        var citaStartMinutes = cita.FechaHoraInicio.Hour * 60 + cita.FechaHoraInicio.Minute;
        var citaEndMinutes = cita.FechaHoraFin.Hour * 60 + cita.FechaHoraFin.Minute;

        var topMinutes = citaStartMinutes - visibleStartMinutes;
        var durationMinutes = citaEndMinutes - citaStartMinutes;

        var pxPerMinute = AltoHoraPx / 60.0;
        var top = topMinutes * pxPerMinute;
        var height = Math.Max(durationMinutes * pxPerMinute, 36);

        return $"top:{top:F0}px; height:{height:F0}px;";
    }

    private string GetEstadoClass(string? estado) => estado?.ToLower() switch
    {
        "confirmada" => "pro-appointment--confirmada",
        "cancelada" => "pro-appointment--cancelada",
        "pendiente" => "pro-appointment--pendiente",
        "completada" => "pro-appointment--completada",
        _ => "pro-appointment--default"
    };
}
