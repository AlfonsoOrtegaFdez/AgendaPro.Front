@page "/registro/clinica"
@layout EmptyLayout
@using AgendaFisio.Front.Models.Auth
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Registrar clínica | AgendaFisio</PageTitle>

<div class="registro-clinica-wrapper">
    <div class="registro-clinica-box">
        <div class="registro-left">
            <span class="registro-badge">Registro de clínica</span>
            <h1>Crea tu clínica en AgendaFisio</h1>
            <p>
                Registra tu clínica, crea tu cuenta de acceso con el rol que corresponda
                y obtén tu código de registro para que tus empleados puedan unirse fácilmente.
            </p>

            <ul class="registro-points">
                <li>Alta rápida de clínica</li>
                <li>Usuario inicial con rol seleccionado</li>
                <li>Código de registro único</li>
                <li>Preparado para gestionar citas y pacientes</li>
            </ul>
        </div>

        <div class="registro-right">
            @if (!registroCompletado)
            {
                <h2>Registrar clínica</h2>

                <div class="form-grid">
                    <div class="form-group full">
                        <label>Nombre de la clínica</label>
                        <input @bind="model.NombreClinica" placeholder="Ej. Fisio Madrid Centro" />
                    </div>

                    <div class="form-group">
                        <label>Teléfono</label>
                        <input @bind="model.TelefonoClinica" placeholder="666666666" />
                    </div>

                    <div class="form-group">
                        <label>Dirección</label>
                        <input @bind="model.DireccionClinica" placeholder="Calle Mayor 25" />
                    </div>

                    <div class="form-group">
                        <label>Nombre</label>
                        <input @bind="model.NombreAdmin" placeholder="Laura" />
                    </div>

                    <div class="form-group">
                        <label>Apellidos</label>
                        <input @bind="model.ApellidosAdmin" placeholder="Martín" />
                    </div>

                    <div class="form-group full">
                        <label>Email</label>
                        <input @bind="model.EmailAdmin" type="email" placeholder="usuario@clinica.com" />
                    </div>

                    <div class="form-group full">
                        <label>Rol</label>
                        <InputSelect @bind-Value="model.Rol" class="form-control">
                            <option value="">Selecciona un rol</option>
                            <option value="Recepcionista">Recepcionista</option>
                            <option value="Profesional">Profesional</option>
                        </InputSelect>
                    </div>

                    <div class="form-group full">
                        <label>Contraseña</label>
                        <input @bind="model.Password" type="password" placeholder="••••••••" />
                    </div>
                </div>

                <button class="btn btn-primary w-full" @onclick="Registrar" disabled="@loading">
                    @(loading ? "Registrando..." : "Crear clínica")
                </button>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="error-box">@error</div>
                }

                <p class="form-footer">
                    ¿Ya tienes cuenta?
                    <a href="/login">Inicia sesión</a>
                </p>
            }
            else
            {
                <div class="success-state">
                    <div class="success-icon">✅</div>
                    <h2>Clínica registrada correctamente</h2>
                    <p>@mensajeExito</p>

                    <div class="codigo-box">
                        <span>Código de registro de tu clínica</span>
                        <strong>@codigoRegistro</strong>
                    </div>

                    <p class="success-help">
                        Guarda este código. Tus empleados lo usarán para registrarse en la clínica.
                    </p>

                    <div class="success-actions">
                        <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/login"))">
                            Ir a iniciar sesión
                        </button>

                        <button class="btn btn-secondary" @onclick="@(() => Nav.NavigateTo("/registro/empleado"))">
                            Registrar empleado
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private RegistroClinicaRequest model = new();
    private bool loading;
    private bool registroCompletado;
    private string error = "";
    private string codigoRegistro = "";
    private string mensajeExito = "";

    private async Task Registrar()
    {
        error = "";
        loading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(model.NombreClinica) ||
                string.IsNullOrWhiteSpace(model.NombreAdmin) ||
                string.IsNullOrWhiteSpace(model.ApellidosAdmin) ||
                string.IsNullOrWhiteSpace(model.EmailAdmin) ||
                string.IsNullOrWhiteSpace(model.Password) ||
                string.IsNullOrWhiteSpace(model.Rol))
            {
                error = "Completa todos los campos obligatorios.";
                return;
            }

            var response = await AuthService.RegistrarClinica(model);

            if (response is null)
            {
                error = "No se pudo completar el registro.";
                return;
            }

            registroCompletado = true;
            codigoRegistro = response.CodigoRegistro;
            mensajeExito = response.Mensaje;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}