@page "/dashboard/recepcion"
@using AgendaFisio.Front.Componentes.Dashboard
@using AgendaFisio.Front.Models

<PageTitle>Recepción | AgendaFisio</PageTitle>

<div class="recepcion-page">
    <div class="recepcion-toolbar">
        <div class="recepcion-toolbar__left">
            <button class="toolbar-btn toolbar-btn--active">Vista Diaria</button>
            <button class="toolbar-btn">Vista Semanal</button>
            <button class="toolbar-btn">↻ Hoy</button>
        </div>

        <div class="recepcion-toolbar__right">
            <button class="toolbar-btn toolbar-btn--primary">+ Nueva Cita</button>
            <button class="toolbar-btn">☰ Filtrar por Profesional</button>
            <input type="text" placeholder="Buscar Paciente" class="toolbar-search__input" />
        </div>
    </div>

    <div class="recepcion-date-header">
        <h2>@DateTime.Today.ToString("dddd dd 'de' MMMM", new System.Globalization.CultureInfo("es-ES"))</h2>
    </div>

    <div class="recepcion-agenda-wrapper">
        <DashboardAgendaDiaria Profesionales="@Profesionales"
                               Citas="@CitasHoy"
                               HoraInicio="8"
                               HoraFin="20"
                               AltoHoraPx="80" />
    </div>
</div>

